# Facebook credentials (pour Le Truck Muche)
# Le token Claude est lu automatiquement depuis le macOS Keychain
# (Claude Code doit être connecté)
FACEBOOK_EMAIL=votre@email.com
FACEBOOK_PASSWORD=votre_mot_de_passe

# Optionnel : profil sportif pour l'agent diététicien
SPORT_PROFILE=musculation
DAILY_CALORIES_TARGET=2500

# Optionnel : override manuel du token Claude (si pas de Keychain disponible)
# ANTHROPIC_API_KEY=sk-ant-...

# Giphy API (pour les GIFs dans les commentaires)
# Créer une app sur https://developers.giphy.com/
GIPHY_API_KEY=votre_cle_giphy

# Vercel (publication automatique des PDJ)
VERCEL_API_URL=https://agroporc.vercel.app
API_SECRET_TOKEN=votre_token_secret
